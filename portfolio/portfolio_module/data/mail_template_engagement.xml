<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="email_template_engagement_custom" model="mail.template">
            <field name="name">Portfolio Module: Engagement Email</field>
            <field name="model_id" ref="portfolio_module.model_portfolio_engagement_log"/>
            <field name="subject">New Custom Module by Amul Babariya: {{ object.module_id.name }}</field>
            <field name="email_from">Amul Babariya &lt;amulbabariya07@gmail.com&gt;</field>
            <field name="email_to">{{ object.client_id.email }}</field>
            <field name="description">Sent to clients when a new module is developed</field>
            <field name="body_html" type="html">
<div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; max-width: 600px; margin: 0 auto; background-color: #ffffff; color: #333333;">
    
    <!-- Clean Top Section -->
    <div style="padding: 30px 20px 10px 20px;">
        <p style="font-size: 16px; margin: 0 0 15px 0; color: #111827;">
            Hello <strong><t t-out="ctx.get('contact_name', object.client_id.name) or 'there'"/></strong>,
        </p>
        <p style="font-size: 15px; line-height: 1.6; margin: 0 0 15px 0; color: #4b5563;">
            I am excited to share a brand new custom Odoo module that I recently developed. It's designed to add value and streamline processes.
        </p>
    </div>

    <!-- Divider -->
    <div style="padding: 0 20px;">
        <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 10px 0 20px 0;"/>
    </div>
    
    <!-- Module Section -->
    <div style="padding: 0 20px; text-align: center;">
        <t t-if="object.module_id.image">
            <div style="margin-bottom: 20px;">
                <img t-att-src="image_data_uri(object.module_id.image)" style="max-width: 100%; height: auto; border-radius: 6px; border: 1px solid #e5e7eb; display: inline-block;" alt="Module Image"/>
            </div>
        </t>
        
        <h2 style="margin: 0 0 10px 0; color: #1f2937; font-size: 22px;">
            <t t-out="object.module_id.name or ''"/>
        </h2>
        
        <t t-if="object.module_id.short_description">
            <p style="margin: 0 0 20px 0; color: #4b5563; font-size: 15px; line-height: 1.6;">
                <t t-out="object.module_id.short_description or ''"/>
            </p>
        </t>
        
        <div style="margin: 30px 0;">
            <a t-attf-href="https://amulbabariya.site/my-modules/{{ object.module_id.id }}" style="background-color: #0284c7; color: #ffffff; padding: 12px 30px; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 15px; display: inline-block;">
                View Module Details
            </a>
        </div>
    </div>
    
    <!-- Clean Footer -->
    <div style="background-color: #f3f4f6; padding: 30px 20px; border-top: 1px solid #e5e7eb; border-radius: 0 0 12px 12px; margin-top: 20px;">
        
        <div style="text-align: center; margin-bottom: 25px;">
            <p style="margin: 0 0 10px 0; font-size: 15px; color: #374151; font-weight: bold;">
                Looking for a dedicated freelance Odoo developer?
            </p>
            <a href="mailto:amulbabariya07@gmail.com" style="color: #0284c7; text-decoration: underline; font-size: 15px;">
                Let's connect and discuss your project!
            </a>
        </div>
        
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td width="50%" align="center" style="border-right: 1px solid #d1d5db;">
                    <a href="https://amulbabariya.site" style="color: #4b5563; text-decoration: none; font-size: 13px; font-weight: bold;">
                        🌐 My Portfolio Website
                    </a>
                </td>
                <td width="50%" align="center">
                    <a href="https://amulbabariya.site/my-modules" style="color: #4b5563; text-decoration: none; font-size: 13px; font-weight: bold;">
                        💼 Explore All Works
                    </a>
                </td>
            </tr>
        </table>
        
        <div style="text-align: center; margin-top: 30px;">
            <p style="margin: 0; font-size: 13px; color: #6b7280;">Best regards,</p>
            <p style="margin: 5px 0 0 0; font-size: 15px; color: #111827; font-weight: bold;">
                <t t-out="user.name or 'Amul Babariya'"/>
            </p>
            <p style="margin: 2px 0 0 0; font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px;">
                Odoo Expert &amp; Freelance Developer
            </p>
        </div>

    </div>
</div>
            </field>
        </record>
    </data>
</odoo>
