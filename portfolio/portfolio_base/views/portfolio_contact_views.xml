<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_portfolio_contact_tree" model="ir.ui.view">
        <field name="name">portfolio.contact.tree</field>
        <field name="model">portfolio.contact</field>
        <field name="arch" type="xml">
            <list string="Contacts" decoration-info="state == 'new'" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="state" widget="badge" decoration-info="state == 'new'" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_portfolio_contact_form" model="ir.ui.view">
        <field name="name">portfolio.contact.form</field>
        <field name="model">portfolio.contact</field>
        <field name="arch" type="xml">
            <form string="Contact Inquiry">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="attachment_name" invisible="1"/>
                            <field name="attachment" filename="attachment_name" widget="binary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Message / Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_portfolio_contact_kanban" model="ir.ui.view">
        <field name="name">portfolio.contact.kanban</field>
        <field name="model">portfolio.contact</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="color"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="attachment"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong class="o_kanban_record_title fs-4 text-primary">
                                            <i class="fa fa-user-circle-o me-2" title="User" aria-label="User"/> <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                        <a class="dropdown-toggle o-no-caret btn btn-sm text-muted p-0" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                            <span class="fa fa-ellipsis-v"/>
                                        </a>
                                        <div class="dropdown-menu" role="menu">
                                            <ul class="oe_kanban_colorpicker" data-field="color"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-muted o_kanban_record_subtitle mt-2">
                                    <div t-if="record.email.raw_value">
                                        <i class="fa fa-envelope-o me-1" title="Email"/> <strong>Email: </strong> <field name="email"/>
                                    </div>
                                    <div t-if="record.phone.raw_value" class="mt-1">
                                        <i class="fa fa-phone me-1" title="Phone"/> <strong>Phone: </strong> <field name="phone"/>
                                    </div>
                                </div>
                                <div class="mt-3 d-flex justify-content-between align-items-center border-top pt-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <button name="action_open_record" type="object" class="btn btn-sm btn-outline-secondary">Open</button>
                                        <span class="badge text-bg-info" t-if="record.attachment.raw_value" title="Has Attachment"><i class="fa fa-paperclip"/></span>
                                    </div>
                                    <div>
                                        <button name="action_in_progress" type="object" class="btn btn-sm btn-primary" t-if="record.state.raw_value == 'new'">In Progress</button>
                                        <button name="action_done" type="object" class="btn btn-sm btn-success" t-if="record.state.raw_value == 'in_progress'">Done</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_portfolio_contact" model="ir.actions.act_window">
        <field name="name">Contact Inquiries</field>
        <field name="res_model">portfolio.contact</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No contact inquiries yet!
            </p>
            <p>
                When visitors submit the contact form, their queries will appear here.
            </p>
        </field>
    </record>

    <!-- Menu Item (Under main portfolio app) -->
    <menuitem id="menu_portfolio_contact" name="Contact Us" parent="menu_portfolio_root" action="action_portfolio_contact" sequence="20"/>

</odoo>
