<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portfolio_experience_tree" model="ir.ui.view">
        <field name="name">portfolio.experience.tree</field>
        <field name="model">portfolio.experience</field>
        <field name="arch" type="xml">
            <list string="Experiences">
                <field name="sequence" widget="handle"/>
                <field name="profile_id"/>
                <field name="company_name"/>
                <field name="role"/>
                <field name="employment_type"/>
                <field name="location"/>
                <field name="start_date"/>
                <field name="is_currently_working"/>
                <field name="end_date" readonly="is_currently_working" required="not is_currently_working"/>
                <field name="experience_duration"/>
            </list>
        </field>
    </record>

    <record id="view_portfolio_experience_form" model="ir.ui.view">
        <field name="name">portfolio.experience.form</field>
        <field name="model">portfolio.experience</field>
        <field name="arch" type="xml">
            <form string="Experience">
                <sheet>
                    <group>
                        <group>
                            <field name="profile_id"/>
                            <field name="company_name"/>
                            <field name="role"/>
                            <field name="employment_type"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="is_currently_working"/>
                            <field name="end_date" invisible="is_currently_working" required="not is_currently_working"/>
                            <field name="experience_duration"/>
                        </group>
                    </group>
                    <separator string="Description"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_portfolio_experience" model="ir.actions.act_window">
        <field name="name">Experiences</field>
        <field name="res_model">portfolio.experience</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_portfolio_experience" name="Experiences" parent="menu_portfolio_root" action="action_portfolio_experience" sequence="30"/>
</odoo>
