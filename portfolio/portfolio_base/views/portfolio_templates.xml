<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portfolio_home_page" name="Portfolio Home Page">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-set="head">
                <link rel="preconnect" href="https://fonts.googleapis.com"/>
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
                <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&amp;display=swap" rel="stylesheet"/>
                <!-- Three.js Library -->
                <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
                <!-- GSAP & ScrollTrigger -->
                <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
                <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
                <link rel="icon" type="image/png" href="/portfolio_base/static/src/img/amul-babariya-favicon.png"/>
            </t>
            <div id="portfolio-wrap" class="portfolio-container" t-if="profile">
                <!-- Scroll Progress Bar -->
                <div class="scroll-progress-container">
                    <div class="scroll-progress-bar" id="scrollBar"></div>
                </div>

                <!-- Animated Background Blobs -->
                <div class="blob-bg blob-1"></div>
                <div class="blob-bg blob-2"></div>
                <div class="blob-bg blob-3"></div>
                
                <!-- Hero Section -->
                <section id="hero" class="d-flex flex-column justify-content-center align-items-center">
                    <!-- WebGL Canvas for 3D Background -->
                    <canvas id="webgl-canvas"></canvas>
                    <div class="hero-shapes">
                        <div class="hero-shape"></div>
                        <div class="hero-shape"></div>
                        <div class="hero-shape"></div>
                        <div class="hero-shape"></div>
                        <div class="hero-shape"></div>
                    </div>
                    <div class="hero-container text-center px-3 container"  >
                        <div class="row justify-content-center">
                            <div class="col-12">
                                <h3 class="greeting-text mb-2 text-muted fs-5" style="font-weight: 600; letter-spacing: 2px;">Hi, I am</h3>
                                <h1 class="portfolio-title display-1 fw-bolder" t-esc="profile.name"/>
                                <p class="portfolio-subtitle lead fs-4 text-muted mt-3 px-md-3" t-esc="profile.short_intro"/>
                                <div class="portfolio-social-links mt-4 d-flex justify-content-center align-items-center flex-wrap gap-3">
                                    <div class="d-flex gap-3">
                                        <a t-if="profile.linkedin_url" t-att-href="profile.linkedin_url if profile.linkedin_url.startswith('http') else 'https://' + profile.linkedin_url" class="linkedin text-decoration-none shadow-sm" target="_blank" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background-color: #0077b5; color: white;"><i class="fa fa-linkedin"></i></a>
                                        <a t-if="profile.github_url" t-att-href="profile.github_url if profile.github_url.startswith('http') else 'https://' + profile.github_url" class="github text-decoration-none shadow-sm" target="_blank" style="border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background-color: #333; color: white;"><i class="fa fa-github"></i></a>
                                    </div>
                                    <div class="d-flex align-items-center flex-wrap gap-2 ms-md-2" style="border-left: 2px solid rgba(0,0,0,0.1); padding-left: 1rem;">
                                        <t t-if="profile.total_experience">
                                            <div class="d-flex align-items-center" style="color: #4b5563; font-size: 1.05rem; font-weight: 500; animation: fadeUp 0.8s ease-out forwards; opacity: 0; transform: translateY(20px);">
                                                <i class="fa fa-briefcase me-2" style="color: #6366f1;"></i>
                                                <span class="portfolio-counter-text" t-att-data-text="profile.total_experience"><t t-esc="profile.total_experience"/></span>
                                            </div>
                                        </t>
                                        <t t-set="mod_count" t-value="len(request.env['portfolio.module'].sudo().search([])) if 'portfolio.module' in request.env else 0"/>
                                        <t t-if="mod_count > 0">
                                            <div class="d-flex align-items-center" style="color: #4b5563; font-size: 1.05rem; font-weight: 500; animation: fadeUp 0.8s ease-out 0.2s forwards; opacity: 0; transform: translateY(20px);">
                                                <i class="fa fa-cubes me-2" style="color: #10b981;"></i>
                                                <span class="portfolio-counter-text" t-att-data-text="str(mod_count) + '+ Modules'"><t t-esc="mod_count"/>+ Modules</span>
                                            </div>
                                        </t>
                                        <style>
                                            @keyframes fadeUp {
                                                to {
                                                    opacity: 1;
                                                    transform: translateY(0);
                                                }
                                            }
                                        </style>
                                    </div>
                                </div>
                                <div class="mt-5 d-flex justify-content-center"  >
                                    <a href="/my-modules" class="cta-unique-shape">
                                        <span class="wave-text">See My Work</span>
                                        <div class="blue-dot"></div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <a href="#about" class="scroll-down-indicator">
                        <span class="small fw-bold mb-1">Scroll Down</span>
                        <i class="fa fa-angle-down"></i>
                    </a>
                </section>

                <!-- About Section -->
                <section id="about" class="about portfolio-section">
                    <div class="container">
                        <div class="section-title text-center">
                            <h2 class="section-heading">About Me</h2>
                        </div>
                        <div class="row mt-5">
                            <div class="col-lg-5 mb-5 mb-lg-0"  >
                                <div class="profile-image-container">
                                    <img t-if="profile.image_1920" t-attf-src="/web/image/portfolio.profile/{{profile.id}}/image_1920" class="img-fluid"/>
                                    <div t-else="" class="profile-img-placeholder text-center p-5 bg-light rounded-4 shadow-sm text-muted">No Image Available</div>
                                </div>
                            </div>
                            <div class="col-lg-7 content ps-lg-5"   >
                                <div t-out="profile.about_me" class="mb-5 lead text-muted"/>
                                <div class="row info-list">
                                    <div class="col-lg-6">
                                        <ul>
                                            <li t-if="profile.date_of_birth"><i class="fa fa-chevron-right"></i> <strong>Birthday:</strong> <span t-esc="profile.date_of_birth"/></li>
                                            <li t-if="profile.city or profile.state_id or profile.country_id"><i class="fa fa-chevron-right"></i> <strong>Address:</strong> 
                                                <span>
                                                    <t t-esc="profile.city"/> <t t-esc="profile.state_id.name"/> <t t-esc="profile.country_id.name"/>
                                                </span>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="col-lg-6">
                                        <ul>
                                            <li t-if="profile.phone"><i class="fa fa-chevron-right"></i> <strong>Phone:</strong> <span t-esc="profile.phone"/></li>
                                            <li t-if="profile.email"><i class="fa fa-chevron-right"></i> <strong>Email:</strong> <span t-esc="profile.email"/></li>
                                            <li t-if="profile.total_experience"><i class="fa fa-chevron-right"></i> <strong>Experience:</strong> <span t-esc="profile.total_experience"/></li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="mt-5 d-flex align-items-center">
                                    <a t-if="profile.resume" t-attf-href="/web/content/portfolio.profile/{{profile.id}}/resume?download=true" class="badge-custom text-decoration-none d-inline-block me-3" target="_blank">
                                        <i class="fa fa-download me-2"></i> Download Resume
                                    </a>
                                    <a id="flying-contact-btn" href="#contact" class="btn btn-outline-primary rounded-pill d-inline-block fw-bold" style="padding: 10px 25px; border-width: 2px;">
                                        Get in Touch
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Experience Section -->
                <section id="experience" class="portfolio-section bg-light" t-if="profile.experience_ids">
                    <div class="container">
                        <div class="section-title text-center">
                            <h2 class="section-heading">Experience</h2>
                        </div>
                        <div class="portfolio-timeline mt-5"  >
                            <t t-set="is_left" t-value="True"/>
                            <t t-foreach="profile.experience_ids" t-as="exp">
                                <div t-attf-class="portfolio-timeline-container {{ 'left' if is_left else 'right' }}" >
                                    <div class="portfolio-timeline-content portfolio-card">
                                        <h4 t-esc="exp.role"/>
                                        <h5 t-esc="exp.company_name"/>
                                        <p class="text-muted small mb-4 fw-bold">
                                            <i class="fa fa-calendar me-2"></i>
                                            <span t-att-title="exp.start_date">
                                                <t t-esc="exp.start_date.strftime('%B %Y') if exp.start_date else ''"/>
                                            </span>
                                            - 
                                            <t t-if="exp.is_currently_working">Present</t>
                                            <t t-else="">
                                                <span t-att-title="exp.end_date">
                                                    <t t-esc="exp.end_date.strftime('%B %Y') if exp.end_date else ''"/>
                                                </span>
                                            </t>
                                            <span class="ms-2">(<t t-esc="exp.experience_duration"/>)</span>
                                        </p>
                                        <div t-out="exp.description" class="text-secondary"/>
                                    </div>
                                </div>
                                <t t-set="is_left" t-value="not is_left"/>
                            </t>
                        </div>
                        <div class="text-center mt-5 pt-4" >
                            <a href="/my-modules" class="cta-kinetic">
                                <span class="kinetic-text">EXPLORE</span>
                                <span class="kinetic-text outline">MODULES</span>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- Education Section -->
                <section id="education" class="portfolio-section" t-if="profile.education_ids">
                    <div class="container">
                        <div class="section-title text-center">
                            <h2 class="section-heading">Education</h2>
                        </div>
                        <div class="row g-4 mt-4">
                            <t t-foreach="profile.education_ids" t-as="edu">
                                <div class="col-md-6">
                                    <div class="portfolio-card edu-card h-100 d-flex align-items-center" >
                                        <div class="edu-icon-box me-4 flex-shrink-0">
                                            <i class="fa fa-graduation-cap"></i>
                                        </div>
                                        <div class="edu-content flex-grow-1">
                                            <h4 class="edu-degree mb-1" t-esc="edu.degree"/>
                                            <h6 class="edu-school text-muted mb-3" t-esc="edu.school_name"/>
                                            <div class="d-flex flex-column gap-2 mt-2 text-muted small fw-semibold">
                                                <span><i class="fa fa-calendar fa-fw me-2 text-primary"></i> 
                                                    <t t-esc="edu.start_year"/> - <t t-esc="'Present' if edu.is_continue else edu.end_year"/>
                                                </span>
                                                <span t-if="edu.score"><i class="fa fa-star fa-fw me-2 text-primary"></i> <t t-esc="edu.score"/></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>

                <!-- Skills Section -->
                <section id="skills" class="portfolio-section bg-light" t-if="profile.skill_ids">
                    <div class="container">
                        <div class="section-title text-center mb-5" >
                            <span class="badge rounded-pill bg-light text-primary px-3 py-2 mb-3" style="font-weight: 600; font-size: 0.9rem; background-color: #e0f2fe !important;">Skills &amp; Expertise</span>
                            <h2 class="display-4 fw-bold text-dark mb-3" style="letter-spacing: -1px; line-height: 1.1;">Technical Proficiency</h2>
                            <p class="text-muted fs-5 mx-auto" style="line-height: 1.6; max-width: 700px;">A comprehensive overview of the programming languages, frameworks, and tools I leverage to build robust and scalable applications.</p>
                        </div>
                        
                        <div class="row justify-content-center g-4 mt-4">
                            <t t-foreach="profile.skill_ids" t-as="skill">
                                <div class="col-lg-4 col-md-6" >
                                    <div class="skill-card-simple h-100">
                                        <div class="card-header-modern d-flex align-items-center w-100 mb-2">
                                            <div class="card-icon-area me-3" style="width: 50px; height: 50px; flex-shrink: 0;">
                                                <t t-if="skill.icon">
                                                    <img t-attf-src="/web/image/portfolio.skill/#{skill.id}/icon" alt="Skill Icon" class="skill-icon-img" style="width: 100%; height: 100%; object-fit: contain;"/>
                                                </t>
                                                <t t-else="">
                                                    <i class="fa fa-code" style="font-size: 2rem; color: #0ea5e9;"></i>
                                                </t>
                                            </div>
                                            <h3 class="card-title-modern mb-0 text-dark fw-bold" style="font-size: 1.5rem;" t-esc="skill.name"/>
                                        </div>
                                        <hr class="w-100 my-2" style="border-top: 1px solid rgba(0,0,0,0.1); opacity: 1;"/>
                                        <div class="card-content w-100 mt-2">
                                            <p class="card-desc-modern text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 0; text-align: left;" t-esc="skill.description or 'Proficient in this skill.'"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        
                        <div class="text-center mt-5 pt-3"  >
                            <a href="/my-modules" class="cta-laser-border">
                                <span>Discover My Odoo Modules <i class="fa fa-arrow-right ms-2"></i></span>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- Languages Section -->
                <section id="languages" class="portfolio-section" t-if="profile.language_ids">
                    <div class="container">
                        <div class="section-title text-center" >
                            <h2 class="section-heading">Languages</h2>
                        </div>
                        <div class="row g-4 justify-content-center mt-5">
                            <t t-foreach="profile.language_ids" t-as="plang">
                                <div class="col-md-3 col-sm-6">
                                    <div class="lang-card" >
                                        <div class="lang-icon">
                                            <i class="fa fa-language"></i>
                                        </div>
                                        <h4 class="lang-name" t-esc="plang.name"/>
                                        
                                        <!-- Calculate dots based on level -->
                                        <t t-set="level_map" t-value="{'beginner': 1, 'intermediate': 2, 'professional': 3, 'native': 4}"/>
                                        <t t-set="level_num" t-value="level_map.get(plang.level, 0)"/>
                                        
                                        <div class="lang-dots">
                                            <t t-foreach="[0, 1, 2, 3]" t-as="i">
                                                <span t-attf-class="lang-dot #{'active' if i &lt; level_num else ''}"></span>
                                            </t>
                                        </div>
                                        
                                        <span class="lang-level-text" t-esc="plang.level.title() if plang.level else ''"/>
                                        
                                        <!-- Info Icon and Custom Tooltip -->
                                        <div class="lang-info-icon" t-if="plang.description">
                                            <i class="fa fa-info-circle"></i>
                                            <div class="lang-tooltip">
                                                <t t-esc="plang.description"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
                
                <!-- Contact Section -->
                <section id="contact" class="portfolio-section" style="position: relative; overflow: hidden;">
                    <div class="contact-header-wrapper mt-5">
                        <h1 class="contact-bg-text">CONTACT</h1>
                        <h2 id="contact-target-text" class="contact-fg-text">GET IN TOUCH</h2>
                    </div>

                    <div class="container pb-5">
                        <div class="row mt-5">
                            <!-- Left Side: Information -->
                            <div class="col-lg-5 mb-5 mb-lg-0 pe-lg-4 pt-lg-4">
                                <h3 class="fw-bold mb-4" style="color: #0f172a; font-size: 2rem;">Let's Connect!</h3>
                                <p class="text-muted mb-5" style="font-size: 1.1rem; line-height: 1.6;">Whether you have an opportunity to discuss, a question to ask, or simply want to say hi, I'd love to hear from you.</p>
                                
                                <div class="d-flex align-items-center mb-4">
                                    <div class="d-flex justify-content-center align-items-center rounded-circle" style="width: 60px; height: 60px; background: rgba(14, 165, 233, 0.1); color: #0ea5e9; font-size: 1.5rem;">
                                        <i class="fa fa-envelope"></i>
                                    </div>
                                    <div class="ms-4">
                                        <h6 class="mb-1 fw-bold text-uppercase" style="letter-spacing: 1px; color: #64748b; font-size: 0.8rem;">Email Me At</h6>
                                        <p class="mb-0 fw-bold" style="color: #0f172a; font-size: 1.1rem;" t-esc="profile.email or 'hello@example.com'"></p>
                                    </div>
                                </div>
                                
                                <div class="d-flex align-items-center mb-4">
                                    <div class="d-flex justify-content-center align-items-center rounded-circle" style="width: 60px; height: 60px; background: rgba(14, 165, 233, 0.1); color: #0ea5e9; font-size: 1.5rem;">
                                        <i class="fa fa-phone"></i>
                                    </div>
                                    <div class="ms-4">
                                        <h6 class="mb-1 fw-bold text-uppercase" style="letter-spacing: 1px; color: #64748b; font-size: 0.8rem;">Call Me At</h6>
                                        <p class="mb-0 fw-bold" style="color: #0f172a; font-size: 1.1rem;" t-esc="profile.phone or '+91 98765 43210'"></p>
                                    </div>
                                </div>
                                
                                <div class="d-flex align-items-center">
                                    <div class="d-flex justify-content-center align-items-center rounded-circle" style="width: 60px; height: 60px; background: rgba(14, 165, 233, 0.1); color: #0ea5e9; font-size: 1.5rem;">
                                        <i class="fa fa-map-marker"></i>
                                    </div>
                                    <div class="ms-4">
                                        <h6 class="mb-1 fw-bold text-uppercase" style="letter-spacing: 1px; color: #64748b; font-size: 0.8rem;">Location</h6>
                                        <t t-set="loc_parts" t-value="[p for p in [profile.city, profile.state_id.name, profile.country_id.name] if p]"/>
                                        <p class="mb-0 fw-bold" style="color: #0f172a; font-size: 1.1rem;" t-esc="', '.join(loc_parts) if loc_parts else 'Surat, Gujarat, India'"></p>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Side: Form -->
                            <div class="col-lg-6 offset-lg-1">
                                <div class="contact-container m-0 w-100" style="padding: 20px 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: none; background: #ffffff;">

                                    <!-- Success Message -->
                                    <div id="ajax-success-message" t-attf-class="text-center py-5 success-animation-container {{ 'd-none' if not submitted else '' }}" style="min-height: 480px; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                                        <div class="success-checkmark mb-4">
                                            <div class="check-icon">
                                                <span class="icon-line line-tip"></span>
                                                <span class="icon-line line-long"></span>
                                                <div class="icon-circle"></div>
                                                <div class="icon-fix"></div>
                                            </div>
                                        </div>
                                        <h3 class="fw-bold mb-2" style="color: #0f172a;">Message Sent!</h3>
                                        <p class="text-muted">Thank you for reaching out. I'll get back to you as soon as possible.</p>
                                        <a href="#" onclick="return resetContactForm();" class="btn btn-outline-primary mt-3 px-4 rounded-pill">Send Another Message</a>
                                    </div>

                                    <form id="ajax-contact-form" action="/contact/submit" method="post" enctype="multipart/form-data" t-attf-class="{{ 'd-none' if submitted else '' }}" onsubmit="return validateContactForm(this);">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <input type="hidden" name="redirect_url" value="/?submitted=1#contact"/>
                                        <div class="row g-2">
                                            <!-- Name -->
                                            <div class="col-md-12">
                                                <label for="name" class="form-label fw-bold text-muted small mb-1">Full Name <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control form-control-sm" id="name" name="name" placeholder="John Doe" required="required"/>
                                            </div>
                                            
                                            <!-- Email -->
                                            <div class="col-md-6">
                                                <label for="email" class="form-label fw-bold text-muted small mb-1">Email Address</label>
                                                <input type="email" class="form-control form-control-sm" id="email" name="email" placeholder="john@example.com"/>
                                            </div>
                                            
                                            <!-- Phone -->
                                            <div class="col-md-6">
                                                <label for="phone" class="form-label fw-bold text-muted small mb-1">Phone Number</label>
                                                <input type="tel" class="form-control form-control-sm" id="phone" name="phone" placeholder="+1 (234) 567-8900"/>
                                                <div class="form-text mt-0" style="font-size: 0.7rem;"><i class="fa fa-info-circle"></i> Email or phone required</div>
                                            </div>

                                            <!-- Description -->
                                            <div class="col-12">
                                                <label for="description" class="form-label fw-bold text-muted small mb-1">Message <span class="text-danger">*</span></label>
                                                <textarea class="form-control form-control-sm" id="description" name="description" rows="2" placeholder="How can I help you?" required="required"></textarea>
                                            </div>

                                            <!-- Custom File Attachment UI -->
                                            <div class="col-12">
                                                <label class="form-label fw-bold text-muted small mb-1">Attach files (Images/PDFs)</label>
                                                
                                                <div class="custom-file-upload-wrapper">
                                                    <div class="upload-dropzone" id="upload-dropzone" onclick="document.getElementById('attachment').click()">
                                                        <i class="fa fa-cloud-upload fa-2x mb-2 text-primary"></i>
                                                        <p class="mb-0 fw-bold" style="color: #334155;">Click to select files or drag and drop</p>
                                                        <p class="text-muted small mb-0">Images, Videos, PDFs, or ZIPs up to 10MB</p>
                                                    </div>
                                                    
                                                    <!-- Hidden actual input -->
                                                    <input type="file" id="attachment" name="attachment" accept="image/*,video/*,.pdf,.zip" multiple="multiple" style="display: none;" onchange="handleFilesSelected(event)"/>
                                                    
                                                    <!-- Preview Container -->
                                                    <div id="file-preview-container" class="mt-3 d-flex flex-wrap gap-2"></div>
                                                </div>
                                            </div>

                                            <!-- Submit -->
                                            <div class="col-12 text-center mt-2">
                                                <button type="submit" class="btn btn-send btn-sm w-100" style="padding: 8px 20px;"><i class="fa fa-paper-plane me-2"></i> Send Message</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Exit Intent Modal -->
                <div class="modal fade" id="exitIntentModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content text-center p-4 shadow-lg border-0" style="border-radius: 20px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
                            <div class="modal-body pb-0">
                                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                                <div class="mb-4">
                                    <i class="fa fa-cubes fa-4x" style="color: #3b82f6;"></i>
                                </div>
                                <h3 class="fw-bold mb-3" style="color: #0f172a;">Wait! Have you seen my modules?</h3>
                                <p class="text-muted mb-4">Before you go, check out my custom Odoo modules and technical solutions that I have built.</p>
                                <a href="/my-modules" class="btn btn-primary rounded-pill fw-bold px-5 py-2 mb-3 w-100 shadow-sm" style="background: linear-gradient(135deg, #3b82f6, #2563eb); border: none;">Explore My Modules <i class="fa fa-arrow-right ms-2"></i></a>
                                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Maybe later</button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div t-else="" class="container text-center d-flex flex-column justify-content-center align-items-center" style="min-height: 100vh;">
                <h1 class="text-muted fw-bold mb-4" style="font-size: 3rem;">No Portfolio Found</h1>
                <p class="text-secondary lead">Please log into the Odoo backend and create a Portfolio Profile to view it here.</p>
            </div>
        </t>
    </template>

    <!-- Hide header and footer specifically on the login page -->
    <template id="hide_login_header_footer" inherit_id="website.login_layout" name="Hide Header/Footer on Login">
        <xpath expr="//t[@t-call='website.layout']" position="inside">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
        </xpath>
    </template>
</odoo>
