<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portfolio_skill_tree" model="ir.ui.view">
        <field name="name">portfolio.skill.tree</field>
        <field name="model">portfolio.skill</field>
        <field name="arch" type="xml">
            <list string="Skills">
                <field name="sequence" widget="handle"/>
                <field name="profile_id"/>
                <field name="name"/>
                <field name="icon" widget="image" options="{'size': [32, 32]}"/>
            </list>
        </field>
    </record>

    <record id="view_portfolio_skill_form" model="ir.ui.view">
        <field name="name">portfolio.skill.form</field>
        <field name="model">portfolio.skill</field>
        <field name="arch" type="xml">
            <form string="Skill">
                <sheet>
                    <group>
                        <group>
                            <field name="profile_id"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="icon" widget="image" options="{'size': [128, 128]}"/>
                        </group>
                    </group>
                    <separator string="Description"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_portfolio_skill" model="ir.actions.act_window">
        <field name="name">Skills</field>
        <field name="res_model">portfolio.skill</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_portfolio_skill" name="Skills" parent="menu_portfolio_root" action="action_portfolio_skill" sequence="40"/>
</odoo>
