<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portfolio_education_tree" model="ir.ui.view">
        <field name="name">portfolio.education.tree</field>
        <field name="model">portfolio.education</field>
        <field name="arch" type="xml">
            <list string="Educations">
                <field name="sequence" widget="handle"/>
                <field name="profile_id"/>
                <field name="school_name"/>
                <field name="degree"/>
                <field name="start_year"/>
                <field name="is_continue"/>
                <field name="end_year" readonly="is_continue" required="not is_continue"/>
                <field name="score"/>
            </list>
        </field>
    </record>

    <record id="view_portfolio_education_form" model="ir.ui.view">
        <field name="name">portfolio.education.form</field>
        <field name="model">portfolio.education</field>
        <field name="arch" type="xml">
            <form string="Education">
                <sheet>
                    <group>
                        <group>
                            <field name="profile_id"/>
                            <field name="school_name"/>
                            <field name="degree"/>
                            <field name="score"/>
                        </group>
                        <group>
                            <field name="start_year"/>
                            <field name="is_continue"/>
                            <field name="end_year" invisible="is_continue" required="not is_continue"/>
                        </group>
                    </group>
                    <separator string="Description"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_portfolio_education" model="ir.actions.act_window">
        <field name="name">Educations</field>
        <field name="res_model">portfolio.education</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_portfolio_education" name="Educations" parent="menu_portfolio_root" action="action_portfolio_education" sequence="20"/>
</odoo>
