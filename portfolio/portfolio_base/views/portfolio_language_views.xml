<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portfolio_language_tree" model="ir.ui.view">
        <field name="name">portfolio.language.tree</field>
        <field name="model">portfolio.language</field>
        <field name="arch" type="xml">
            <list string="Languages">
                <field name="profile_id"/>
                <field name="name"/>
                <field name="level"/>
            </list>
        </field>
    </record>

    <record id="view_portfolio_language_form" model="ir.ui.view">
        <field name="name">portfolio.language.form</field>
        <field name="model">portfolio.language</field>
        <field name="arch" type="xml">
            <form string="Language">
                <sheet>
                    <group>
                        <field name="profile_id"/>
                        <field name="name"/>
                        <field name="level"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_portfolio_language" model="ir.actions.act_window">
        <field name="name">Languages</field>
        <field name="res_model">portfolio.language</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_portfolio_language" name="Languages" parent="menu_portfolio_root" action="action_portfolio_language" sequence="50"/>
</odoo>
