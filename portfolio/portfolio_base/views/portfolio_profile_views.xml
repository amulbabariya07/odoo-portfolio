<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_portfolio_profile_tree" model="ir.ui.view">
        <field name="name">portfolio.profile.tree</field>
        <field name="model">portfolio.profile</field>
        <field name="arch" type="xml">
            <list string="Profiles">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="city"/>
                <field name="total_experience"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_portfolio_profile_form" model="ir.ui.view">
        <field name="name">portfolio.profile.form</field>
        <field name="model">portfolio.profile</field>
        <field name="arch" type="xml">
            <form string="Profile">
                <header>
                    <!-- Header buttons can be added here -->
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Smart buttons can go here -->
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. John Doe"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_of_birth"/>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="total_experience"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <label for="city" string="Address"/>
                            <div class="o_address_format">
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True}"/>
                                <field name="country_id" placeholder="Country" class="o_address_country" options="{'no_open': True}"/>
                            </div>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="General info" name="general_info">
                            <group>
                                <field name="short_intro" placeholder="A brief introduction about yourself..."/>
                                <field name="linkedin_url" widget="url"/>
                                <field name="github_url" widget="url"/>
                                <field name="resume_name" invisible="1"/>
                                <field name="resume" filename="resume_name" widget="binary"/>
                            </group>
                            <separator string="About Me"/>
                            <field name="about_me" widget="html"/>
                        </page>
                        <page string="Experience" name="experience">
                            <field name="experience_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="company_name"/>
                                    <field name="role"/>
                                    <field name="employment_type"/>
                                    <field name="location"/>
                                    <field name="start_date"/>
                                    <field name="is_currently_working"/>
                                    <field name="end_date" readonly="is_currently_working" required="not is_currently_working"/>
                                    <field name="experience_duration"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="company_name"/>
                                            <field name="role"/>
                                            <field name="employment_type"/>
                                            <field name="location"/>
                                        </group>
                                        <group>
                                            <field name="start_date"/>
                                            <field name="is_currently_working"/>
                                            <field name="end_date" invisible="is_currently_working" required="not is_currently_working"/>
                                            <field name="experience_duration"/>
                                        </group>
                                    </group>
                                    <separator string="Description"/>
                                    <field name="description"/>
                                </form>
                            </field>
                        </page>
                        <page string="Education" name="education">
                            <field name="education_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="school_name"/>
                                    <field name="degree"/>
                                    <field name="start_year"/>
                                    <field name="is_continue"/>
                                    <field name="end_year" readonly="is_continue" required="not is_continue"/>
                                    <field name="score"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="school_name"/>
                                            <field name="degree"/>
                                            <field name="score"/>
                                        </group>
                                        <group>
                                            <field name="start_year"/>
                                            <field name="is_continue"/>
                                            <field name="end_year" invisible="is_continue" required="not is_continue"/>
                                        </group>
                                    </group>
                                    <separator string="Description"/>
                                    <field name="description"/>
                                </form>
                            </field>
                        </page>
                        <page string="Skills" name="skills">
                            <field name="skill_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="icon" widget="image" options="{'size': [32, 32]}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Languages" name="languages">
                            <field name="language_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="level"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_portfolio_profile" model="ir.actions.act_window">
        <field name="name">Portfolio Profiles</field>
        <field name="res_model">portfolio.profile</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Portfolio Profile
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_portfolio_root" name="Portfolio" web_icon="portfolio_base,static/src/img/portfolio.png" sequence="100"/>
    
    <menuitem id="menu_portfolio_profile" name="Profiles" parent="menu_portfolio_root" action="action_portfolio_profile" sequence="10"/>

</odoo>
